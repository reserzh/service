{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fieldservice/api-types": ["../../packages/api-types/src"],
      "@fieldservice/api-types/*": ["../../packages/api-types/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "../../packages/api-types/src/**/*.ts"
  ]
}
